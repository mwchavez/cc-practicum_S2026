#ifndef SECRETS_H
#define SECRETS_H

// ── Wi-Fi ────────────────────────────────────────────────
#define WIFI_SSID     "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// ── AWS IoT Core ─────────────────────────────────────────
// Get your endpoint with:
//   aws iot describe-endpoint --endpoint-type iot:Data-ATS
// It looks like: xxxxxx-ats.iot.us-east-1.amazonaws.com
#define AWS_IOT_ENDPOINT "xxxxxx-ats.iot.us-east-1.amazonaws.com"
#define AWS_IOT_PORT     8883

// MQTT topic — matches the IoT Rule SQL: SELECT * FROM 'leaksensor/+/data'
#define MQTT_TOPIC "leaksensor/node-01/data"

// A unique client ID for this device
#define MQTT_CLIENT_ID "leaksensor-node-01"

// ── Certificates ─────────────────────────────────────────
// Paste the contents of each file between the raw string delimiters.
// Do NOT remove the newlines — PEM format requires them.

// Amazon Root CA 1  (AmazonRootCA1.pem)
static const char AWS_ROOT_CA[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_YOUR_ROOT_CA_HERE
-----END CERTIFICATE-----
)EOF";

// Device certificate  (xxxxxxxxxx-certificate.pem.crt)
static const char AWS_DEVICE_CERT[] PROGMEM = R"EOF(
-----BEGIN CERTIFICATE-----
PASTE_YOUR_DEVICE_CERTIFICATE_HERE
-----END CERTIFICATE-----
)EOF";

// Device private key  (xxxxxxxxxx-private.pem.key)
static const char AWS_PRIVATE_KEY[] PROGMEM = R"EOF(
-----BEGIN RSA PRIVATE KEY-----
PASTE_YOUR_PRIVATE_KEY_HERE
-----END RSA PRIVATE KEY-----
)EOF";

#endif // SECRETS_H
